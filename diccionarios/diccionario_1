import random

def es_valida_luhn(numero_tarjeta):
    """Aplica el algoritmo de Luhn para verificar la validez."""
    digitos = [int(d) for d in str(numero_tarjeta)]
    # El último dígito es el número de control (checksum)
    control = digitos.pop()
    
    # Invertimos los dígitos restantes
    digitos.reverse()
    
    # Doblamos los dígitos en posiciones impares (0, 2, 4...)
    for i in range(len(digitos)):
        if i % 2 == 0:
            digitos[i] *= 2
            if digitos[i] > 9:
                digitos[i] -= 9
    
    total = sum(digitos) + control
    return total % 10 == 0

def buscar_tarjeta_valida():
    intentos = 0
    while True:
        intentos += 1
        # Generar un número aleatorio de 16 dígitos
        numero = "".join([str(random.randint(0, 9)) for _ in range(16)])
        
        if es_valida_luhn(numero):
            print(f"¡Tarjeta válida encontrada en el intento {intentos}!")
            print(f"Número: {numero}")
            break

# Ejecutar la búsqueda
buscar_tarjeta_valida()
